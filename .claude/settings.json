{
  "permissions": {
    "ask": [
      "Bash(git push origin main*)",
      "Bash(git push -u origin main*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(gh pr merge*)",
      "Bash(gh workflow run*)",
      "Bash(gh run rerun*)",
      "Bash(supabase db push*)",
      "Bash(supabase db reset*)",
      "Bash(supabase functions deploy*)",
      "Bash(supabase link*)",
      "Bash(npx supabase db push*)",
      "Bash(npx supabase db reset*)",
      "Bash(npx supabase functions deploy*)",
      "Bash(npx supabase link*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/production-guard.mjs\"",
            "timeout": 10,
            "statusMessage": "Production guard check"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/production-guard.mjs\"",
            "timeout": 10,
            "statusMessage": "Production guard check"
          }
        ]
      }
    ]
  }
}
